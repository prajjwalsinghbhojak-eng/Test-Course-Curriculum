# .env.monitor — AI Learning Monitor configuration
#
# ┌─────────────────────────────────────────────────────────────────┐
# │  LEARNER SETUP: Only one value to fill in                       │
# │                                                                 │
# │  1. Copy this file:  cp _monitoring_app/.env.monitor.example .env.monitor       │
# │  2. Paste the token from your instructor into MONITOR_PUSH_TOKEN│
# │  3. Re-run setup:    bash _monitoring_app/setup.sh   (Mac/Linux/Codespaces)     │
# │                      python _monitoring_app/setup.py  (Windows)                 │
# └─────────────────────────────────────────────────────────────────┘
#
# Everything else is pre-configured. Do not edit unless instructed.

# ── FILL THIS IN ──────────────────────────────────────────────────────────
# Token provided by your instructor. Allows your progress logs to be
# sent to the team dashboard. Keep this private — do not commit this file.
MONITOR_PUSH_TOKEN=

# ── AI API keys (required for capstone phase) ─────────────────────────────
# Gemini CLI key — needed when using Gemini during the capstone project.
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Pre-configured — do not change ───────────────────────────────────────
# Central monitoring repo where all learner logs are collected.
MONITOR_REPO_URL=https://github.com/LatentviewIT/learning-monitor-reports

# Branch within that repo where logs land.
MONITOR_REPORTS_BRANCH=monitoring-reports

# ── Advanced overrides (leave blank unless instructed) ────────────────────
# Maximum characters stored per field in JSONL events.
MONITOR_STRING_TRUNCATE=300
MONITOR_PROMPT_TEXT_TRUNCATE=1000

# Notebook completion threshold (0.9 = 90% of cells must be executed).
MONITOR_NOTEBOOK_COMPLETE_THRESHOLD=0.9

# Seconds to suppress duplicate filesystem events for the same file.
MONITOR_FS_DEBOUNCE_WINDOW=2.0
