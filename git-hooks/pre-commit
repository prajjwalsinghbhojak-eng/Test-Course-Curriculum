#!/usr/bin/env python3
"""
git-hooks/pre-commit
Runs before every commit. Captures:
  - Files being committed
  - Whether tests exist and pass
  - Presence of planning artifacts
Writes a structured event to git_events.jsonl
"""

import subprocess
import sys
import os
import json
import datetime
import fcntl

REPO_ROOT = subprocess.check_output(
    ["git", "rev-parse", "--show-toplevel"], text=True
).strip()

sys.path.insert(0, REPO_ROOT)
os.environ["REPO_ROOT"] = REPO_ROOT

from monitor.config import GIT_LOG_FILE, LEARNER_ID, PLANNING_PATTERNS, TEST_OUTPUT_TRUNCATE_LENGTH
from monitor.event_writer import write_event


def get_staged_files() -> list[str]:
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only"],
        capture_output=True, text=True
    )
    return [f.strip() for f in result.stdout.splitlines() if f.strip()]


def has_test_files(files: list[str]) -> bool:
    return any(
        "test_" in f or "_test" in f or "/tests/" in f
        for f in files
    )


def run_tests() -> tuple[bool, str]:
    """Run pytest if present. Returns (passed: bool, summary: str)."""
    result = subprocess.run(
        ["python3", "-m", "pytest", "--tb=no", "-q", "--no-header"],
        capture_output=True, text=True, cwd=REPO_ROOT
    )
    passed = result.returncode == 0
    summary = (result.stdout + result.stderr).strip()[-TEST_OUTPUT_TRUNCATE_LENGTH:]
    return passed, summary


def has_planning_artifacts() -> bool:
    import os
    for dirpath, _, filenames in os.walk(REPO_ROOT):
        if ".git" in dirpath:
            continue
        for fname in filenames:
            low = fname.lower()
            if any(p in low for p in PLANNING_PATTERNS):
                return True
    return False


def main():
    staged = get_staged_files()
    has_tests = has_test_files(staged)
    tests_passed, test_summary = run_tests() if has_tests else (None, "no tests found")
    has_planning = has_planning_artifacts()

    write_event(GIT_LOG_FILE, "pre_commit", {
        "files_staged": staged,
        "files_changed": len(staged),
        "has_tests": has_tests,
        "tests_passed": tests_passed,
        "test_summary": test_summary,
        "has_planning_artifacts": has_planning,
    })

    # Don't block commits — monitoring only
    sys.exit(0)


if __name__ == "__main__":
    main()
